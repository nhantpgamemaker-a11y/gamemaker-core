<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <ui:Label text="Label" name="TitleLabel" style="-unity-text-align: upper-center; -unity-font-style: bold; border-bottom-width: 1px; border-left-color: rgba(0, 0, 0, 0.5); border-right-color: rgba(0, 0, 0, 0.5); border-top-color: rgba(0, 0, 0, 0.5); border-bottom-color: rgba(0, 0, 0, 0.5); padding-bottom: 2px;"/>
    <ui:ListView name="ItemListView" show-border="false" allow-add="false" allow-remove="false" reorderable="true" focusable="false" show-add-remove-footer="false" virtualization-method="DynamicHeight" style="flex-shrink: 0; flex-basis: initial;"/>
</ui:UXML>
